ll sides so the subject sits close to the edges but is never cropped or touching the frame.\nStyle: sharp, elegant, high-contrast, clean etched portraiture.\nAvoid: blur, gray wash, painterly texture, messy noise, muddy stippling, heavy cross-hatching, weak contrast, cropped edges.","",","]},{"id":201,"type":"Image Comparer (rgthree)","pos":[3389.183511064627,272.70420016672347],"size":[714.184486813538,792.7160584546275],"flags":{},"order":45,"mode":0,"inputs":[{"dir":3,"name":"image_a","type":"IMAGE","link":318},{"dir":3,"name":"image_b","type":"IMAGE","link":320}],"outputs":[],"properties":{"comparer_mode":"Slide","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.8"}},"widgets_values":[[{"name":"A","selected":true,"url":"/api/view?filename=rgthree.compare._temp_pxrcs_00014_.png&type=temp&subfolder=&rand=0.07054638041084005"},{"name":"B","selected":true,"url":"/api/view?filename=rgthree.compare._temp_pxrcs_00015_.png&type=temp&subfolder=&rand=0.7816330230149316"}]]},{"id":60,"type":"SaveImage","pos":[2396.7132785613476,369.6495034574047],"size":[721.8238185318196,802.4723356847626],"flags":{},"order":44,"mode":0,"inputs":[{"name":"images","type":"IMAGE","link":319}],"outputs":[],"properties":{"Node name for S&R":"SaveImage","cnr_id":"comfy-core","ver":"0.3.48","ue_properties":{"version":"7.2.1","widget_ue_connectable":{},"input_ue_unconnectable":{}},"enableTabs":false,"tabWidth":65,"tabXOffset":10,"hasSecondTab":false,"secondTabText":"Send Back","secondTabOffset":80,"secondTabWidth":65},"widgets_values":["ComfyUI"]},{"id":172,"type":"easy int","pos":[1345.5548539962847,1161.7191711363307],"size":[270,58],"flags":{},"order":23,"mode":0,"inputs":[],"outputs":[{"name":"int","type":"INT","links":[307]}],"title":"height","properties":{"Node name for S&R":"easy int","cnr_id":"comfyui-easy-use","ver":"3f37ba9491fa7f6c8520dda6cf92a8e2dcbee8fa","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.2.1"}},"wi